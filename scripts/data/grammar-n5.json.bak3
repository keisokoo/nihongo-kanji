    {
      "no": 41,
      "pattern": "な-adjectives",
      "romaji": "na-adjectives",
      "ref": "https://jlptsensei.com/learn-japanese-grammar/japanese-%e3%81%aa-adjectives-%e3%81%aa%e5%bd%a2%e5%ae%b9%e8%a9%9e-meaning/",
      "refOriginalEn": "na-adjectives",
      "meaningsKo": [
        "나형용사"
      ],
      "category": "verb_form",
      "explanation": "어미가 「な」 로 명사를 수식하는 형용사 (静か(な), きれい(な), 元気(な)). 일본어 형용사의 두 종류 중 하나로, 명사처럼 활용하며 단정 だ/です 를 따라간다.\n\n【형성 규칙】 (어간 + 단정 활용 — copula 와 같은 패턴)\n• 현재 긍정: 어간 + だ / です — 静かだ / 静かです\n• 현재 부정: 어간 + じゃない / ではない / じゃありません — 静かじゃない / 静かじゃありません\n• 과거 긍정: 어간 + だった / でした — 静かだった / 静かでした\n• 과거 부정: 어간 + じゃなかった / じゃありませんでした — 静かじゃなかった\n• て형 (연결): 어간 + で — 静かで、〜 (이유·연결)\n• 부사형: 어간 + に — 静かに書く (~하게)\n• 명사 수식: 어간 + な + 명사 — 静かな部屋\n\n【예외】\n• きれい·嫌い·有名 등 「い」 로 끝나도 な형용사 — 어미 い가 어간의 일부\n• 同じ — 명사 수식 시 「な」 없이 바로 명사 (同じ本, 同じな本 X)\n\n【파생 표현】 な형용사 어간·활용형 위에 결합:\n• 어간 + さ (명사화: 静かさ), 어간 + そう (양태: 元気そう)\n• 〜になる (~해지다), 〜にする (~하게 하다)\n• 보통형 (だ/だった) 위에 〜だろう / 〜らしい / 〜のだ 등 결합 (copula 와 동일)",
      "formation": "어간 + だ/だった/じゃない/じゃなかった (서술) / 어간 + な + 명사 (수식)",
      "notes": "「きれい」 「ゆうめい」 등은 い로 끝나지만 「な」 형용사이므로 주의 (例: きれいな花, きれいだった).",
      "applicableQuizTypes": [
        "conjugation",
        "form_meaning"
      ],
      "examples": [
        {
          "sentence": "ここは{{しずかな}}{町|まち}です。",
          "sentenceTranslationKo": "여기는 조용한 동네입니다.",
          "note": "수식"
        },
        {
          "sentence": "{試験|しけん}は{{大変だった}}。",
          "sentenceTranslationKo": "시험은 힘들었다.",
          "note": "과거"
        }
      ],
      "quizzes": [
        {
          "type": "conjugation",
          "payload": {
            "dictForm": "静か",
            "group": "na_adj",
            "targetFormLabel": "명사 수식형",
            "answer": "静かな",
            "distractors": [
              "静かい",
              "静かの",
              "静かだ"
            ],
            "hintKo": "な형용사 + 명사 = 어간 + な + 명사"
          }
        },
        {
          "type": "conjugation",
          "payload": {
            "dictForm": "便利",
            "group": "na_adj",
            "targetFormLabel": "부정형",
            "answer": "便利じゃない",
            "distractors": [
              "便利くない",
              "便利ない",
              "便利ではい"
            ],
            "hintKo": "な형용사 부정 = 어간 + じゃない"
          }
        },
        {
          "type": "form_meaning",
          "payload": {
            "prompt": "「{有名|ゆうめい}だった」",
            "contextSentence": null,
            "answer": "유명했다",
            "distractors": [
              "유명하다",
              "유명하지 않다",
              "유명할 것이다"
            ]
          }
        }
      ],
      "ruleFamily": "adj:na",
      "isFoundation": true
    },
