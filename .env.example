DATABASE_URL=postgres://nihongo:nihongo@localhost:9433/nihongo

# TTS (Gemini, required)
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# Text generation provider:
# - If ANTHROPIC_API_KEY is set, uses Claude (haiku-4-5 default, sonnet-4-6 premium).
# - If ANTHROPIC_API_KEY is empty/unset, falls back to Gemini using GEMINI_API_KEY.
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5
ANTHROPIC_PREMIUM_MODEL=claude-sonnet-4-6
GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
GEMINI_PREMIUM_MODEL=gemini-3-flash-preview
